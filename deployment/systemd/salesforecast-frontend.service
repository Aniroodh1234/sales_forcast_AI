[Unit]
Description=SalesCast AI Frontend (Next.js)
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/Sales_forcasting_System/frontend
Environment="NODE_ENV=production"
Environment="PORT=3000"
ExecStart=/usr/bin/npm run start

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
